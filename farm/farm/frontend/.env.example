# =============================================================================
# FarmERP Frontend — Environment Variables Reference
# =============================================================================
# Copy this file to .env for local development.
# For Vercel production, set these in the Vercel Dashboard:
#   Settings → Environment Variables → Production
# =============================================================================

# ─── Backend API URL (Railway) ────────────────────────────────────────────
# Development: leave blank → Vite proxy forwards /api to localhost:8000
# Production: leave blank → same-origin via Vercel proxy (vercel.json rewrites)
#             To call Railway directly, set to your Railway URL:
#             VITE_API_URL=https://your-app.up.railway.app
VITE_API_URL=

# ─── WebSocket URL (for live GPS tracking + notifications) ────────────────
# Development: leave blank → auto-resolves to ws://localhost:8000
# Vercel does NOT proxy WebSocket, so in production set this:
# VITE_WS_URL=wss://your-app.up.railway.app
VITE_WS_URL=

# ─── Supabase (Auth + Storage) ────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── Map Tiles (LocationIQ / MapTiler) ────────────────────────────────────
# Falls back to OpenStreetMap if blank
# VITE_LOCATION_TRACKING_API_KEY=

# ─── WebSocket Toggle ─────────────────────────────────────────────────────
# Set to "false" to disable WebSocket (polling-only)
# VITE_ENABLE_WEBSOCKET=true
