# =============================================================================
# FarmERP Frontend — Environment Variables Reference
# =============================================================================
# Copy this file to .env for local development.
# For Vercel production, set these in the Vercel Dashboard:
#   Settings → Environment Variables → Production
# =============================================================================

# ─── Backend API ──────────────────────────────────────────────────────────
# The Render backend URL (no trailing slash).
# Dev: leave blank → Vite proxy forwards /api to localhost:8000
# Prod: https://farmerp-api.onrender.com
VITE_API_URL=

# WebSocket URL for live GPS tracking & notifications.
# Dev: leave blank → resolves to ws://localhost:8000 automatically
# Prod: wss://farmerp-api.onrender.com
VITE_WS_URL=

# ─── Supabase (Auth & Storage) ────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── Map Tiles ────────────────────────────────────────────────────────────
# MapTiler API key for raster map tiles.
# Falls back to OpenStreetMap tiles automatically if blank.
VITE_LOCATION_TRACKING_API_KEY=8NpCatjl2jymfNJ69FRK

# ─── WebSocket Toggle ─────────────────────────────────────────────────────
# Set to "false" to disable WebSocket connections (polling-only fallback).
# Omit or set to "true" to enable.
# VITE_ENABLE_WEBSOCKET=true
