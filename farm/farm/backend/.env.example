# =============================================================================
# FarmERP Backend — Environment Variables Reference
# =============================================================================
# Copy this file to .env for local development.
# For Railway production, set these in the Railway Dashboard:
#   Dashboard → farmerp-backend → Variables
# =============================================================================

# ─── Django ────────────────────────────────────────────────────────────────
SECRET_KEY=django-insecure-dev-key-change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,farmerp-backend-production.up.railway.app

# ─── Database (PostgreSQL) ─────────────────────────────────────────────────
# Local PostgreSQL:
DB_NAME=farmerp
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# OR — set DATABASE_URL to use Supabase (for Railway deployment):
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@aws-0-ap-southeast-2.pooler.supabase.com:6543/postgres

# ─── JWT ───────────────────────────────────────────────────────────────────
ACCESS_TOKEN_LIFETIME_MIN=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# ─── CORS ──────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000,https://farmerp1.vercel.app
CSRF_TRUSTED_ORIGINS=https://farmerp1.vercel.app

# ─── LocationIQ (Map Reverse Geocoding) ───────────────────────────────────
# Get your free API key at https://locationiq.com/
LOCATIONIQ_API_KEY=your_locationiq_api_key_here

# ─── Media / Storage (optional S3) ────────────────────────────────────────
USE_S3=False
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=

# ─── Email (for forgot-password OTP) ──────────────────────────────────────
# Option A: Resend (recommended — developer-friendly)
#   Sign up at https://resend.com → API Keys → Create API key
# EMAIL_HOST=smtp.resend.com
# EMAIL_HOST_USER=resend
# EMAIL_HOST_PASSWORD=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# Option B: Gmail SMTP
# EMAIL_HOST=smtp.gmail.com
# EMAIL_HOST_USER=your_email@gmail.com
# EMAIL_HOST_PASSWORD=your_app_password
# DEFAULT_FROM_EMAIL=your_email@gmail.com

# Common email settings:
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_PORT=587
EMAIL_USE_TLS=True
